# ───────────────────────────────────────────────────────────────
# mesa — variáveis de ambiente
# Copie para `.env` e preencha. NUNCA commite o `.env`.
# ───────────────────────────────────────────────────────────────

# --- Banco de dados (PostgreSQL) ---
# Local (ex.: Docker): postgresql://USER:PASS@localhost:5432/mesa?schema=public
# Vercel Postgres / Neon / Supabase: use a connection string deles.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mesa?schema=public"

# --- Login (usuário único: você) ---
# Senha única de acesso ao console.
APP_PASSWORD="troque-esta-senha"
# Chave para assinar o cookie de sessão (HMAC). Gere algo aleatório e longo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="cole-aqui-uma-chave-aleatoria-de-64-hex"

# --- LinkedIn OAuth + Posts API ---
LINKEDIN_CLIENT_ID="seu-client-id"
LINKEDIN_CLIENT_SECRET="seu-client-secret"
# Tem que bater EXATAMENTE com a "Authorized redirect URL" no app do LinkedIn.
# Local:       http://localhost:3000/api/auth/linkedin/callback
# Produção:    https://SEU-DOMINIO/api/auth/linkedin/callback
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"
# Versão da API do LinkedIn (formato AAAAMM). NUNCA hardcode no código — vem daqui.
# Use uma versão recente e suportada do seu app. Ex.: 202506
LINKEDIN_API_VERSION="202506"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."
# Modelo de geração. Padrão no código é gpt-4o se não definido.
OPENAI_MODEL="gpt-4o"

# --- Cron (agendamento) ---
# Segredo que protege /api/cron/publish. A Vercel injeta CRON_SECRET nos
# crons automaticamente se a env existir; agendadores externos devem mandar
# o header  Authorization: Bearer <CRON_SECRET>.
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET="cole-aqui-um-segredo-aleatorio"
